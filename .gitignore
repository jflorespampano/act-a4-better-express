# Dependencias
node_modules/

yarn.lock
pnpm-lock.yaml

# Variables de entorno y configuraciones sensibles
.env
.env.*
!.env.example      # Excluir el archivo de ejemplo si existe
*.pem
*.key
*.crt

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Archivos de salida de compilación / transpilación
dist/
build/
out/
*.tsbuildinfo

# Cobertura de pruebas (coverage)
coverage/
.nyc_output/

# Directorios de sistema
.DS_Store          # macOS
Thumbs.db          # Windows
desktop.ini

# Archivos de editores / IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Archivos temporales del sistema operativo
*.tmp
*.temp

# Archivos de backup
*.bak
*.old

# Archivos generados por herramientas de debugging
debug.log

# Datos locales de la base de datos (si usas SQLite local)
*.db
*.sqlite
*.sqlite3

# Archivos de sesión (si usas sessions en archivos)
sessions/

# Archivos de carga (uploads) locales
uploads/
temp/

# Archivos de configuración local de herramientas
.eslintcache
.prettierrc.cache

# Archivos de entorno de producción específicos
.env.production.local
.env.development.local
.env.test.local